    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "ngrok": "^5.0.0-beta.2",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "localtunnel": "^2.0.2"
  }
}
