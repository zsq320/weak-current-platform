# 弱电工程管理平台 - 环境变量配置
# 复制此文件为 .env 并填写配置

# 服务端口
PORT=3000

# 运行环境
NODE_ENV=development

# SMTP 邮件配置（用于发送邮箱验证码）
# QQ邮箱示例：
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your授权码

# 163邮箱示例：
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_USER=your-email@163.com
# SMTP_PASS=your授权码

# 阿里云短信配置（可选，暂未接入）
# ALIYUN_ACCESS_KEY=your-access-key
# ALIYUN_SECRET_KEY=your-secret-key
