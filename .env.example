# 弱电工程管理平台 - 环境变量配置
# 复制此文件为 .env 并填写配置

# ==================== 基础配置 ====================
# 服务端口
PORT=3000

# 运行环境 (development / production)
NODE_ENV=development

# 数据库文件路径（Docker部署时自动设置为 /data/data.db）
# DB_PATH=./data.db

# ==================== 安全配置（必需）====================
# JWT 密钥 - 必须设置，至少32个字符
# 生成命令: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-change-me

# 刷新令牌密钥（可选，默认使用 JWT_SECRET）
# REFRESH_SECRET=your-refresh-secret-key

# 敏感数据加密密钥（用于身份证、银行卡等）
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-encryption-key-32-bytes-change-me

# CORS 允许的域名（生产环境必须设置，多个用逗号分隔）
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ==================== 邮件配置 ====================
# SMTP 邮件配置（用于发送邮箱验证码）
# QQ邮箱示例：
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your授权码

# 163邮箱示例：
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_USER=your-email@163.com
# SMTP_PASS=your授权码

# ==================== 短信配置（可选）====================
# 阿里云短信配置
# ALIYUN_ACCESS_KEY=your-access-key
# ALIYUN_SECRET_KEY=your-secret-key
